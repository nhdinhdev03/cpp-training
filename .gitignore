*.obj
*.elf

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Build directories
build/
bin/
lib/
dist/
target/

# CMake files
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Code::Blocks
*.cbp
*.layout
*.depend

# CLion
cmake-build-*/

# Visual Studio
*.vcxproj*
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# Qt Creator
*.pro.user
*.pro.user.*

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.orig

